    "version": "0.2.0",
    "configurations": [
        {
            "name": "game_hub",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "game_hub (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "game_hub (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        {

            "name": "Flutter Web (Sem Segurança)",
            "request": "launch",
            "type": "dart",
            "args": [
                "-d", "chrome",
                "--web-browser-flag", "--disable-web-security"
            ]
        }
    ]
}
    
